# Octopus local open-source backend
SERVER_PORT=8080
GIN_MODE=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# release mode requires explicit HTTPS CORS origins; wildcards are rejected

# PostgreSQL
# Local example:
# DB_DSN=host=localhost user=octopus password=octopus dbname=octopus port=5432 sslmode=disable TimeZone=Asia/Shanghai
# Supabase Cloud (YiJian frontend dev): use Direct connection port 5432, not pooler 6543.
# DB_DSN=host=db.<project-ref>.supabase.co user=postgres password=<password> dbname=postgres port=5432 sslmode=require TimeZone=Asia/Shanghai
DB_DRIVER=postgres
DB_DSN=host=localhost user=octopus password=octopus dbname=octopus port=5432 sslmode=disable TimeZone=Asia/Shanghai

# Local workflow/runtime paths
# Windows frontend-dev example:
# OUTPUT_DIR=D:/data/octopus/output
# TEMPLATE_DIR=D:/data/octopus/templates
# ARCHIVE_DIR=D:/data/octopus/archive
# STORAGE_LOCAL_DIR=D:/data/octopus/uploads
OUTPUT_DIR=/mnt/data/output
TEMPLATE_DIR=/mnt/data/templates
ARCHIVE_DIR=/mnt/data/archive
ARCHIVE_CLEANUP=false
DEFAULT_EXECUTOR=local
MINIWDL_PATH=miniwdl

# Local uploads
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/mnt/data/uploads
UPLOAD_MAX_SIZE_MB=0

# Sepiida Server is optional but recommended for live progress.
# For YiJian UI-only local dev (seed data, no real WDL runs), set SEPIIDA_ENABLED=false.
SEPIIDA_ENABLED=true
SEPIIDA_URL=http://localhost:9090
SEPIIDA_QUERY_KEY=
SEPIIDA_QUERY_KEY_FILE=

# Parquet/result data
# For UI-only local dev with seed data, set PARQUET_ENABLED=false.
PARQUET_ENABLED=true
PARQUET_DIR=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_SECRET_FILE=
JWT_ISSUER=octopus
JWT_EXPIRE=24h
JWT_REFRESH=168h
JWT_COOKIE_DOMAIN=
JWT_COOKIE_SECURE=false
# release mode requires JWT_COOKIE_SECURE=true
CLIENT_PASSWORD_HASH_ENABLED=false

# Default admin is created automatically outside release mode.
# In release mode, set CREATE_DEFAULT_ADMIN=true and use a strong password.
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@octopus.local
DEFAULT_ADMIN_PASSWORD=change-me-before-use

# Optional OpenAI-compatible LLM
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o
LLM_ALLOWED_MODELS=          # comma-separated model whitelist, "*" = no restriction, default = LLM_MODEL
LLM_PROXY_MAX_BODY_MB=2      # AI proxy max request body size (MB)

# Optional trusted gateway auth (for a SaaS overlay such as Squid)
EXTERNAL_AUTH_ENABLED=false
EXTERNAL_AUTH_SHARED_SECRET=
EXTERNAL_AUTH_SHARED_SECRET_FILE=
EXTERNAL_AUTH_HEADER=X-Octopus-External-Auth
EXTERNAL_AUTH_USER_ID_HEADER=X-Octopus-User-ID
EXTERNAL_AUTH_EMAIL_HEADER=X-Octopus-User-Email
EXTERNAL_AUTH_ROLE_HEADER=X-Octopus-User-Role
EXTERNAL_AUTH_ORG_ID_HEADER=X-Octopus-Org-ID

# Optional external policy/event overlay. Disabled for community deployments.
OVERLAY_ENABLED=false
OVERLAY_BASE_URL=
OVERLAY_SHARED_SECRET=
OVERLAY_SHARED_SECRET_FILE=
OVERLAY_TIMEOUT=5s
OVERLAY_FAIL_OPEN=false
OVERLAY_TASK_ADMISSION_PATH=/api/v1/overlay/tasks/admit
OVERLAY_TASK_EVENT_PATH=/api/v1/overlay/tasks/events
