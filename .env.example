# Octopus local open-source backend
SERVER_PORT=8080
GIN_MODE=debug
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# PostgreSQL
DB_DRIVER=postgres
DB_DSN=host=localhost user=octopus password=octopus dbname=octopus port=5432 sslmode=disable TimeZone=Asia/Shanghai

# Local workflow/runtime paths
OUTPUT_DIR=/mnt/data/output
TEMPLATE_DIR=/mnt/data/templates
ARCHIVE_DIR=/mnt/data/archive
ARCHIVE_CLEANUP=false
DEFAULT_EXECUTOR=local
MINIWDL_PATH=miniwdl

# Local uploads
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/mnt/data/uploads
UPLOAD_MAX_SIZE_MB=0

# Sepiida Server is optional but recommended for live progress.
SEPIIDA_ENABLED=true
SEPIIDA_URL=http://localhost:9090
SEPIIDA_QUERY_KEY=

# Parquet/result data
PARQUET_ENABLED=true
PARQUET_DIR=

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ISSUER=octopus
JWT_EXPIRE=24h
JWT_REFRESH=168h
JWT_COOKIE_DOMAIN=
JWT_COOKIE_SECURE=false
CLIENT_PASSWORD_HASH_ENABLED=false

# Default admin is created automatically outside release mode.
# In release mode, set CREATE_DEFAULT_ADMIN=true and use a strong password.
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_EMAIL=admin@octopus.local
DEFAULT_ADMIN_PASSWORD=change-me-before-use

# Optional OpenAI-compatible LLM
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=gpt-4o
